@model SchoolMS.Models.Teacher
@{
    ViewData["Title"] = "Teacher Details";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold"><i class="fas fa-chalkboard-teacher me-2 text-warning"></i>Teacher Details</h4>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-1"></i>Back</a>
</div>

<div class="row g-3">
    <div class="col-md-4">
        <div class="card text-center">
            <div class="card-body py-4">
                <div class="bg-warning text-dark rounded-circle d-flex align-items-center justify-content-center mx-auto mb-3"
                     style="width:80px;height:80px;font-size:2rem;">
                    <i class="fas fa-user-tie"></i>
                </div>
                <h5 class="fw-bold">@Model.FullName</h5>
                <p class="text-muted mb-1">@Model.Email</p>
                @if (Model.Phone != null)
                {
                    <p class="text-muted mb-1"><i class="fas fa-phone me-1"></i>@Model.Phone</p>
                }
                <p class="text-muted small"><i class="fas fa-calendar me-1"></i>Joined: @Model.JoinDate.ToString("MMM dd, yyyy")</p>
            </div>
        </div>
    </div>
    <div class="col-md-8">
        <div class="card mb-3">
            <div class="card-header"><i class="fas fa-book me-2 text-info"></i>Assigned Subjects (@Model.TeacherSubjects.Count)</div>
            <div class="card-body p-0">
                <table class="table mb-0">
                    <thead><tr><th>Subject</th><th>Class</th><th>Assigned On</th></tr></thead>
                    <tbody>
                        @foreach (var ts in Model.TeacherSubjects)
                        {
                            <tr>
                                <td>@ts.Subject.Name</td>
                                <td><span class="badge bg-primary">@ts.Subject.Class.Name</span></td>
                                <td>@ts.AssignedAt.ToString("MMM dd, yyyy")</td>
                            </tr>
                        }
                        @if (!Model.TeacherSubjects.Any())
                        {
                            <tr><td colspan="3" class="text-muted text-center py-3">No subjects assigned</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card">
            <div class="card-header"><i class="fas fa-calendar-check me-2 text-success"></i>Recent Attendance</div>
            <div class="card-body p-0">
                <table class="table mb-0">
                    <thead><tr><th>Date</th><th>Status</th></tr></thead>
                    <tbody>
                        @foreach (var a in Model.Attendances.OrderByDescending(x => x.AttendanceDate).Take(10))
                        {
                            <tr class="@(a.IsPresent ? "attendance-present" : "attendance-absent")">
                                <td>@a.AttendanceDate.ToString("MMM dd, yyyy")</td>
                                <td><span class="badge @(a.IsPresent ? "bg-success" : "bg-danger")">@(a.IsPresent ? "Present" : "Absent")</span></td>
                            </tr>
                        }
                        @if (!Model.Attendances.Any())
                        {
                            <tr><td colspan="2" class="text-muted text-center py-3">No attendance records</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>