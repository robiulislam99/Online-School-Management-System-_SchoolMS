@model SchoolMS.Models.Subject
@{
    ViewData["Title"] = "Add Subject";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold"><i class="fas fa-book me-2 text-warning"></i>Add Subject</h4>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-1"></i>Back</a>
</div>

<div class="card" style="max-width:600px;">
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>
            <div class="mb-3">
                <label asp-for="Name" class="form-label">Subject Name *</label>
                <input asp-for="Name" class="form-control" placeholder="e.g. Mathematics" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="ClassId" class="form-label">Class *</label>
                <select asp-for="ClassId" asp-items="ViewBag.Classes" class="form-select">
                    <option value="">-- Select Class --</option>
                </select>
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="form-label">Description</label>
                <textarea asp-for="Description" class="form-control" rows="2"></textarea>
            </div>
            <button type="submit" class="btn btn-warning px-4">
                <i class="fas fa-save me-1"></i>Save
            </button>
        </form>
    </div>
</div>