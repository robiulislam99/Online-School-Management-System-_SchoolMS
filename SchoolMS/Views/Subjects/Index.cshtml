@model List<SchoolMS.Models.Subject>
@{
    ViewData["Title"] = "Subjects";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold"><i class="fas fa-book me-2 text-warning"></i>Subjects</h4>
    <a asp-action="Create" class="btn btn-warning"><i class="fas fa-plus me-1"></i> Add Subject</a>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Subject Name</th>
                    <th>Class</th>
                    <th>Description</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="5" class="text-center text-muted py-4">No subjects found.</td></tr>
                }
                @foreach (var s in Model)
                {
                    <tr>
                        <td>@s.Id</td>
                        <td><i class="fas fa-book text-info me-2"></i>@s.Name</td>
                        <td><span class="badge bg-primary">@s.Class.Name</span></td>
                        <td>@(s.Description ?? "-")</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@s.Id" class="btn btn-sm btn-outline-warning"><i class="fas fa-edit"></i></a>
                            <form asp-action="Delete" asp-route-id="@s.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('Delete?')">
                                <button type="submit" class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>