@model List<SchoolMS.Models.Class>
@{
    ViewData["Title"] = "Classes";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold"><i class="fas fa-chalkboard me-2 text-warning"></i>Classes</h4>
    <a asp-action="Create" class="btn btn-warning"><i class="fas fa-plus me-1"></i> Add Class</a>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Class Name</th>
                        <th>Students</th>
                        <th>Subjects</th>
                        <th>Description</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">
                                <i class="fas fa-inbox fa-2x d-block mb-2"></i>No classes found. Add one!
                            </td>
                        </tr>
                    }
                    @foreach (var c in Model)
                    {
                        <tr>
                            <td>@c.Id</td>
                            <td><strong>@c.Name</strong></td>
                            <td><span class="badge bg-primary">@c.Students.Count</span></td>
                            <td><span class="badge bg-info">@c.Subjects.Count</span></td>
                            <td>@(c.Description ?? "-")</td>
                            <td>
                                <a asp-action="Details" asp-route-id="@c.Id" class="btn btn-sm btn-outline-info"><i class="fas fa-eye"></i></a>
                                <a asp-action="Edit" asp-route-id="@c.Id" class="btn btn-sm btn-outline-warning"><i class="fas fa-edit"></i></a>
                                <form asp-action="Delete" asp-route-id="@c.Id" method="post" class="d-inline"
                                      onsubmit="return confirm('Delete this class?')">
                                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>