@model SchoolMS.Models.StudentMark
@{ ViewData["Title"] = "Add Marks"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold">
        <i class="fas fa-plus-circle me-2 text-warning"></i>Add Marks
    </h4>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left me-1"></i>Back
    </a>
</div>

<div class="card" style="max-width:600px;">
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" 
                 class="alert alert-danger py-2"></div>

            <div class="mb-3">
                <label asp-for="StudentId" class="form-label">
                    Student *
                </label>
                @if (ViewBag.Students != null)
                {
                    <select asp-for="StudentId" 
                            asp-items="ViewBag.Students" 
                            class="form-select">
                        <option value="">-- Select Student --</option>
                    </select>
                }
                else
                {
                    <div class="alert alert-warning py-2">
                        No students found. 
                        <a href="/Students/Create">Add a student first</a>
                    </div>
                }
                <span asp-validation-for="StudentId" 
                      class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="SubjectId" class="form-label">
                    Subject *
                </label>
                @if (ViewBag.Subjects != null)
                {
                    <select asp-for="SubjectId" 
                            asp-items="ViewBag.Subjects" 
                            class="form-select">
                        <option value="">-- Select Subject --</option>
                    </select>
                }
                else
                {
                    <div class="alert alert-warning py-2">
                        No subjects found. 
                        <a href="/Subjects/Create">Add a subject first</a>
                    </div>
                }
                <span asp-validation-for="SubjectId" 
                      class="text-danger small"></span>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label asp-for="ObtainedMarks" class="form-label">
                        Obtained Marks *
                    </label>
                    <input asp-for="ObtainedMarks" 
                           type="number" step="0.5" 
                           class="form-control" />
                    <span asp-validation-for="ObtainedMarks" 
                          class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="TotalMarks" class="form-label">
                        Total Marks *
                    </label>
                    <input asp-for="TotalMarks" 
                           type="number" step="0.5" 
                           class="form-control" value="100" />
                    <span asp-validation-for="TotalMarks" 
                          class="text-danger small"></span>
                </div>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label asp-for="ExamType" class="form-label">
                        Exam Type
                    </label>
                    <select asp-for="ExamType" class="form-select">
                        <option value="">-- Select --</option>
                        <option>Quiz</option>
                        <option>Mid Term</option>
                        <option>Final Term</option>
                        <option>Assignment</option>
                        <option>Practical</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label asp-for="ExamDate" class="form-label">
                        Exam Date
                    </label>
                    <input asp-for="ExamDate" 
                           type="date" class="form-control" />
                </div>
            </div>

            <button type="submit" class="btn btn-warning px-4">
                <i class="fas fa-save me-1"></i>Save Marks
            </button>
        </form>
    </div>
</div>