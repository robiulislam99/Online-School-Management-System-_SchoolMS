@model List<SchoolMS.Models.ClassFee>
@{
    ViewData["Title"] = "Class Fees";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold"><i class="fas fa-money-bill me-2 text-warning"></i>Class Fees</h4>
    <a asp-action="Create" class="btn btn-warning"><i class="fas fa-plus me-1"></i> Add Fee</a>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead><tr><th>Class</th><th>Fee Type</th><th>Amount</th><th>Description</th><th>Actions</th></tr></thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="5" class="text-center text-muted py-4">No fees defined.</td></tr>
                }
                @foreach (var f in Model)
                {
                    <tr>
                        <td><span class="badge bg-primary">@f.Class.Name</span></td>
                        <td>@f.FeeType</td>
                        <td class="fw-bold">@f.Amount.ToString("N0")</td>
                        <td class="text-muted">@(f.Description ?? "-")</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@f.Id" class="btn btn-sm btn-outline-warning"><i class="fas fa-edit"></i></a>
                            <form asp-action="Delete" asp-route-id="@f.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('Delete?')">
                                <button type="submit" class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>