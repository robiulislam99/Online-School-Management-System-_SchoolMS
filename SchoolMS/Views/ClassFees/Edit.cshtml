@model SchoolMS.Models.ClassFee
@{
    ViewData["Title"] = "Edit Class Fee";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold"><i class="fas fa-edit me-2 text-warning"></i>Edit Class Fee</h4>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-1"></i>Back</a>
</div>

<div class="card" style="max-width:550px;">
    <div class="card-body">
        <form asp-action="Edit" method="post">
            <input asp-for="Id" type="hidden" />
            <div class="mb-3">
                <label asp-for="ClassId" class="form-label">Class *</label>
                <select asp-for="ClassId" asp-items="ViewBag.Classes" class="form-select"></select>
            </div>
            <div class="mb-3">
                <label asp-for="FeeType" class="form-label">Fee Type *</label>
                <select asp-for="FeeType" class="form-select">
                    <option>Monthly Fee</option>
                    <option>Annual Fee</option>
                    <option>Admission Fee</option>
                    <option>Exam Fee</option>
                    <option>Transport Fee</option>
                    <option>Other</option>
                </select>
            </div>
            <div class="mb-3">
                <label asp-for="Amount" class="form-label">Amount *</label>
                <input asp-for="Amount" type="number" step="0.01" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="form-label">Description</label>
                <textarea asp-for="Description" class="form-control" rows="2"></textarea>
            </div>
            <button type="submit" class="btn btn-warning px-4"><i class="fas fa-save me-1"></i>Update</button>
        </form>
    </div>
</div>