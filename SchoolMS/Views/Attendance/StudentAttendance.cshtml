@model List<SchoolMS.Models.Student>
@{
    ViewData["Title"] = "Student Attendance"; var existing = ViewBag.ExistingAttendance as List<SchoolMS.Models.StudentAttendance>; var date = (DateTime)ViewBag.Date; var classId = ViewBag.ClassId;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold"><i class="fas fa-calendar-check me-2 text-warning"></i>Student Attendance</h4>
    <a asp-action="ViewStudentAttendance" class="btn btn-outline-info"><i class="fas fa-list me-1"></i>View History</a>
</div>

<div class="card mb-3">
    <div class="card-body py-2">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label">Select Class</label>
                <select name="classId" asp-items="ViewBag.Classes" class="form-select">
                    <option value="">-- Select Class --</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Date</label>
                <input type="date" name="date" value="@ViewBag.Date?.ToString("yyyy-MM-dd")" class="form-control" />
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-warning w-100">Load</button>
            </div>
        </form>
    </div>
</div>

@if (Model.Any())
{
    <div class="card">
        <div class="card-header d-flex justify-content-between">
            <span>Attendance for <strong>@date.ToString("dddd, MMMM dd yyyy")</strong></span>
            <div>
                <button class="btn btn-sm btn-success me-1" onclick="markAll(true)"><i class="fas fa-check me-1"></i>All Present</button>
                <button class="btn btn-sm btn-danger" onclick="markAll(false)"><i class="fas fa-times me-1"></i>All Absent</button>
            </div>
        </div>
        <div class="card-body">
            <form asp-action="SaveStudentAttendance" method="post">
                <input type="hidden" name="date" value="@date.ToString("yyyy-MM-dd")" />
                <input type="hidden" name="classId" value="@classId" />
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead><tr><th>Roll #</th><th>Student Name</th><th>Status</th></tr></thead>
                        <tbody>
                            @foreach (var s in Model)
                            {
                                var isPresent = existing?.Any(a => a.StudentId == s.Id && a.IsPresent) ?? true;
                                <tr id="srow-@s.Id" class="@(existing != null ? (isPresent ? "attendance-present" : "attendance-absent") : "attendance-present")">
                                    <td>@(s.RollNumber ?? "-")</td>
                                    <td><i class="fas fa-user-graduate text-primary me-2"></i>@s.FullName</td>
                                    <td>
                                        <input type="hidden" name="studentIds" value="@s.Id" />
                                        <div class="form-check form-switch d-flex align-items-center gap-2">
                                            <input class="form-check-input att-toggle" type="checkbox" name="presentIds"
                                                   value="@s.Id" @(isPresent ? "checked" : "")
                                                   data-row="srow-@s.Id" style="width:2.5em;height:1.3em;" />
                                            <label class="form-check-label att-label">@(isPresent ? "Present" : "Absent")</label>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <button type="submit" class="btn btn-warning px-4"><i class="fas fa-save me-1"></i>Save Attendance</button>
            </form>
        </div>
    </div>
}
else if (classId != null)
{
    <div class="alert alert-info">No students in this class.</div>
}
else
{
    <div class="alert alert-secondary"><i class="fas fa-info-circle me-2"></i>Please select a class to take attendance.</div>
}

@section Scripts {
    <script>
        document.querySelectorAll('.att-toggle').forEach(cb => {
            cb.addEventListener('change', function () {
                const row = document.getElementById(this.dataset.row);
                const label = this.closest('.form-check').querySelector('.att-label');
                if (this.checked) { row.className = 'attendance-present'; label.textContent = 'Present'; }
                else { row.className = 'attendance-absent'; label.textContent = 'Absent'; }
            });
        });
        function markAll(present) {
            document.querySelectorAll('.att-toggle').forEach(cb => {
                cb.checked = present;
                cb.dispatchEvent(new Event('change'));
            });
        }
    </script>
}