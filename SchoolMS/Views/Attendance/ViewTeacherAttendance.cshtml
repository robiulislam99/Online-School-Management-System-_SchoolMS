@model List<SchoolMS.Models.TeacherAttendance>
@{
    ViewData["Title"] = "Teacher Attendance History";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold"><i class="fas fa-list me-2 text-warning"></i>Teacher Attendance History</h4>
    <a asp-action="TeacherAttendance" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-1"></i>Back</a>
</div>

<div class="card mb-3">
    <div class="card-body py-2">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-3">
                <select name="teacherId" asp-items="ViewBag.Teachers" class="form-select">
                    <option value="">All Teachers</option>
                </select>
            </div>
            <div class="col-md-3">
                <input type="date" name="from" value="@ViewBag.From?.ToString("yyyy-MM-dd")" class="form-control" />
            </div>
            <div class="col-md-3">
                <input type="date" name="to" value="@ViewBag.To?.ToString("yyyy-MM-dd")" class="form-control" />
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-warning w-100">Filter</button>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead><tr><th>Teacher</th><th>Date</th><th>Status</th></tr></thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="3" class="text-center text-muted py-4">No records.</td></tr>
                }
                @foreach (var a in Model.OrderByDescending(x => x.AttendanceDate))
                {
                    <tr>
                        <td>@a.Teacher.FullName</td>
                        <td>@a.AttendanceDate.ToString("MMM dd, yyyy")</td>
                        <td><span class="badge @(a.IsPresent ? "bg-success" : "bg-danger")">@(a.IsPresent ? "Present" : "Absent")</span></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>