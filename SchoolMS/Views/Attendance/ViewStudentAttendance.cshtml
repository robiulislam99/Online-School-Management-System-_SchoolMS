@model List<SchoolMS.Models.StudentAttendance>
@{
    ViewData["Title"] = "Student Attendance History";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold"><i class="fas fa-list me-2 text-warning"></i>Student Attendance History</h4>
    <a asp-action="StudentAttendance" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-1"></i>Back</a>
</div>

<div class="card mb-3">
    <div class="card-body py-2">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-3">
                <select name="classId" asp-items="ViewBag.Classes" class="form-select">
                    <option value="">All Classes</option>
                </select>
            </div>
            <div class="col-md-3">
                <select name="studentId" asp-items="ViewBag.Students" class="form-select">
                    <option value="">All Students</option>
                </select>
            </div>
            <div class="col-md-2">
                <input type="date" name="from" value="@ViewBag.From?.ToString("yyyy-MM-dd")" class="form-control" />
            </div>
            <div class="col-md-2">
                <input type="date" name="to" value="@ViewBag.To?.ToString("yyyy-MM-dd")" class="form-control" />
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-warning w-100">Filter</button>
            </div>
        </form>
    </div>
</div>

@{
    var totalPresent = Model.Count(a => a.IsPresent); var totalAbsent = Model.Count(a => !a.IsPresent);
}
<div class="row g-3 mb-3">
    <div class="col-auto">
        <div class="alert alert-success py-2 mb-0"><i class="fas fa-check me-1"></i><strong>Present: @totalPresent</strong></div>
    </div>
    <div class="col-auto">
        <div class="alert alert-danger py-2 mb-0"><i class="fas fa-times me-1"></i><strong>Absent: @totalAbsent</strong></div>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead><tr><th>Student</th><th>Class</th><th>Date</th><th>Status</th></tr></thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="4" class="text-center text-muted py-4">No records found.</td></tr>
                }
                @foreach (var a in Model)
                {
                    <tr class="@(a.IsPresent ? "attendance-present" : "attendance-absent")">
                        <td>@a.Student.FullName</td>
                        <td><span class="badge bg-primary">@a.Student.Class.Name</span></td>
                        <td>@a.AttendanceDate.ToString("MMM dd, yyyy")</td>
                        <td><span class="badge @(a.IsPresent ? "bg-success" : "bg-danger")">@(a.IsPresent ? "Present" : "Absent")</span></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>